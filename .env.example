# ── EmailJS Configuration ──────────────────────────────────────────────────────
#
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
#
# How to get these values:
#   1. Sign up at https://www.emailjs.com
#   2. Create an Email Service (connect your Gmail/Outlook)
#   3. Create an Email Template using variables:
#        {{from_name}}, {{from_email}}, {{subject}}, {{message}}
#   4. Copy keys from:
#        Service ID  → Email Services tab
#        Template ID → Email Templates tab
#        Public Key  → Account → API Keys
#
# For Vercel deployment, add these under:
#   Project → Settings → Environment Variables

NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id_here
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id_here
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key_here
